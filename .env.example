# ──────────────────────────────────────────────────────────────
# EcoTrack AI — environment variables
# ──────────────────────────────────────────────────────────────
# Copy to `.env` for local development. Never commit real secrets.
# In Lovable, secrets are managed via Project Settings → Secrets,
# not via a committed .env file.
# ──────────────────────────────────────────────────────────────

# Server-only — Lovable AI Gateway key (auto-provisioned in Lovable Cloud).
# Required by src/lib/ai/chat.functions.ts (ecoChat, ecoRecommendations).
LOVABLE_API_KEY=your-lovable-ai-gateway-key

# Standard Node env. Defaults to "development" locally, "production" in build.
NODE_ENV=development

# ──────────────────────────────────────────────────────────────
# Public (VITE_*) variables are inlined into the client bundle.
# Never put secrets behind a VITE_ prefix.
# ──────────────────────────────────────────────────────────────
# VITE_APP_NAME=EcoTrack AI